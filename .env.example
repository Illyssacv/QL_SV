# Sao chép thành .env và chỉnh mật khẩu.

# Chạy app trên máy Windows/Mac, MySQL trong Docker: giữ 127.0.0.1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# Cổng host map tới container (tránh trùng nếu máy đã có MySQL)
MYSQL_PUBLISH_PORT=3306

MYSQL_DATABASE=school
MYSQL_USER=school_user
MYSQL_PASSWORD=change_me_app

MYSQL_ROOT_PASSWORD=change_me_root
